# Copy values into docker-compose.yml or a compose override for local use.
# For production, keep these in your secret manager / host environment.

ENVIRONMENT=staging

POSTGRES_DB=options_saas
POSTGRES_USER=options_user
POSTGRES_PASSWORD=options_password

SECRET_KEY=change-me-before-production
ALGORITHM=HS256

DATABASE_URL_ADMIN=postgresql+psycopg://options_user:options_password@db:5432/options_saas
DATABASE_URL_APP=postgresql+psycopg://options_user:options_password@db:5432/options_saas

REDIS_URL=redis://redis:6379/0

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14

REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_SECURE=true
REFRESH_COOKIE_SAMESITE=none
REFRESH_COOKIE_DOMAIN=
REFRESH_COOKIE_PATH=/v1/auth

FRONTEND_URL=https://your-frontend-domain.example
CORS_ORIGINS=https://your-frontend-domain.example

RESET_PASSWORD_TOKEN_EXPIRE_MINUTES=60
VERIFY_EMAIL_TOKEN_EXPIRE_MINUTES=1440

VITE_API_URL=http://localhost:8000
VITE_API_VERSION=v1

