ENVIRONMENT=development

SECRET_KEY=change_me_local_secret_key_at_least_32_chars
ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14

REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
REFRESH_COOKIE_DOMAIN=
REFRESH_COOKIE_PATH=/v1/auth

FRONTEND_URL=http://localhost:4173

DATABASE_URL_APP=postgresql+psycopg://options_user:change_me_db_password@db:5432/options_saas

CORS_ORIGINS=http://localhost:4173,http://127.0.0.1:4173

REDIS_URL=redis://redis:6379/0

RESET_PASSWORD_TOKEN_EXPIRE_MINUTES=60
VERIFY_EMAIL_TOKEN_EXPIRE_MINUTES=1440

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

BACKEND_PORT=8000
RUN_MIGRATIONS=true
