# Database Configuration
DATABASE_URL_APP=postgresql://username:password@localhost:5432/dbname

# Security
SECRET_KEY=change-me-in-env
ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14

REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
REFRESH_COOKIE_DOMAIN=
REFRESH_COOKIE_PATH=/v1/auth

FRONTEND_URL=http://localhost:5173

RESET_PASSWORD_TOKEN_EXPIRE_MINUTES=60
VERIFY_EMAIL_TOKEN_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173,http://127.0.0.1:4173

# Redis
REDIS_URL=redis://localhost:6379/0

# Sentry (optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
